# CarbonXchange Local Development Environment Variables
# Copy this file to .env and fill in values before running docker compose
# NEVER commit .env to version control

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=dev-root-password-change-me
MYSQL_DATABASE=carbonxchangedb
MYSQL_USER=appuser
MYSQL_PASSWORD=dev-db-password-change-me

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=dev-redis-password-change-me

# ── Backend secrets (min 32 chars for encryption key) ─────────────────────────
JWT_SECRET=dev-jwt-secret-at-least-32-chars-long
ENCRYPTION_KEY=dev-encryption-key-exactly-32chars!
API_KEY_SALT=dev-api-key-salt-change-me

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

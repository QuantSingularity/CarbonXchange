---
# group_vars/all/vault.yml.example
# Rename to vault.yml and encrypt with: ansible-vault encrypt vault.yml
# All variables below MUST be set in the encrypted vault.yml

# Database credentials
vault_database_root_password: "CHANGE_ME_root_password"
vault_database_password: "CHANGE_ME_app_password"

# Application secrets
vault_jwt_secret: "CHANGE_ME_jwt_secret_min_32_chars_long"
vault_encryption_key: "CHANGE_ME_32_char_encryption_key!!"
vault_api_key_salt: "CHANGE_ME_api_key_salt"

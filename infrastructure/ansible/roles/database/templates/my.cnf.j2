# MariaDB configuration - managed by Ansible
# /etc/my.cnf.d/server.cnf

[mysqld]
# Networking
bind-address            = 0.0.0.0
max_connections         = {{ database_max_connections }}
max_allowed_packet      = {{ database_max_allowed_packet }}

# Character set
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# InnoDB
innodb_buffer_pool_size = {{ database_innodb_buffer_pool_size }}
innodb_log_file_size    = {{ database_innodb_log_file_size }}
innodb_flush_log_at_trx_commit = 1
innodb_file_per_table   = ON

# Logging (required for financial compliance)
general_log             = ON
general_log_file        = /var/log/mysql/general.log
slow_query_log          = ON
slow_query_log_file     = /var/log/mysql/slow.log
long_query_time         = 2
log_error               = /var/log/mysql/error.log
log_bin                 = /var/log/mysql/mysql-bin
expire_logs_days        = 30
binlog_format           = ROW

# Security hardening
local_infile            = OFF
symbolic-links          = 0
skip_name_resolve       = ON
sql_mode                = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[client]
default-character-set   = utf8mb4

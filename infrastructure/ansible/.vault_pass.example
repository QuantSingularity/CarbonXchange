# .vault_pass.example
# Create .vault_pass with your vault password and set permissions:
#   chmod 600 .vault_pass
# Then configure ansible.cfg or pass --vault-password-file=.vault_pass
#
# For CI/CD, use:
#   export ANSIBLE_VAULT_PASSWORD_FILE=/path/to/.vault_pass
# or
#   ansible-playbook ... --vault-password-file=.vault_pass
#
# NEVER commit .vault_pass to version control — it is in .gitignore
